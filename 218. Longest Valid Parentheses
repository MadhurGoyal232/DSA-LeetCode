class Solution {
    public int longestValidParentheses(String s) {
        int left = 0;
        int right = 0;
        int max = 0;
        for(int i=0;i<s.length();i++){
            char x = s.charAt(i);            

            if(x == '('){
                left++;
            }else{

                right++;
            }

            if(right>left){
                left = 0;
                right = 0;
            }
            if(left == right){
                max = Math.max(max, left*2);
            }           
        }
        left = 0;
        right = 0;
        for(int i=s.length()-1;i>=0;i--){
            char x = s.charAt(i);            

            if(x == ')'){
                left++;
            }else{

                right++;
            }

            if(right>left){
                left = 0;
                right = 0;
            }
            if(left == right){
                max = Math.max(max, left*2);
            }           
        }
        
        return max;
    }
}
