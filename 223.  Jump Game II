class Solution {
    public int jump(int[] nums) {
        int l = 0;
        int r = 0;
        int n = nums.length;
        int jumps = 0;
        int farthest = 0;
        while(r<n-1){
            
            for(int i=l;i<=r;i++){
                farthest = Math.max(farthest, i+nums[i]);
            }
            l = r+1;
            r = farthest;
            jumps = jumps+1;
        }
        return jumps;
    }
}
