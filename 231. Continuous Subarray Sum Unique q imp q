class Solution {
    public boolean checkSubarraySum(int[] nums, int k) {
        //tricky question logic

        HashMap<Integer, Integer> map = new HashMap<>();
        map.put(0,-1);
        int sum = 0;
        for(int i=0;i<nums.length;i++){
            sum+= nums[i];
            int mod = sum%k;

            if(map.containsKey(mod)){
                int len = i - map.get(mod);
                if(len>1){
                    return true;
                }
            }else{
                map.put(mod, i);
            }

        }
        return false;
    }
}
