class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int left = 0;
        int right = 0;
        double avg = 0.0;
        int count = 0;
        double ans = Double.NEGATIVE_INFINITY;
        double ans = -1000000.0;
        while(right<nums.length){
            if(count!= k){
                avg+=nums[right];
                count++;
                
            }
            if(count == k){
                ans = Math.max(ans, avg);
                avg-= nums[left];
                left++;
                count--;
                
            }
            right++;
        

        }
        return ans/k;
    }
}
